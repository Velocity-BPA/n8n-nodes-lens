{
  "name": "n8n-nodes-lens",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Lens Protocol providing 14 resources and 60+ operations for decentralized social graph interactions. Includes profiles, publications, follows, reactions, collects, feeds, groups, and poll-based triggers.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-lens.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-lens",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-lens/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "lens",
    "lens-protocol",
    "web3",
    "social-graph",
    "decentralized",
    "blockchain",
    "polygon",
    "lens-chain",
    "graphql",
    "social-media",
    "nft",
    "automation"
  ],
  "main": "dist/nodes/Lens/Lens.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/LensApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Lens/Lens.node.js",
      "dist/nodes/Lens/LensTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}